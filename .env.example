# Documentation only. This file lists which secrets the app expects.
# Real values NEVER live here or anywhere in the repo. They are stored in
# the macOS Keychain and read at runtime via the Security framework.
# Assume this repo is public.

# Ollama Cloud (optional; only if the user selects the Ollama Cloud provider)
# Keychain service: "askmail.ollama-cloud"  account: "api-key"
OLLAMA_API_KEY=

# Mistral API (optional; only if the user selects the Mistral provider)
# Keychain service: "askmail.mistral"  account: "api-key"
MISTRAL_API_KEY=

# Local Ollama needs no key. Default host:
OLLAMA_HOST=http://localhost:11434
